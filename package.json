{
  "name": "ruledoc",
  "version": "0.1.1",
  "description": "Business rules documentation generator — extract @rule() annotations from code and generate Markdown, JSON and HTML docs.",
  "keywords": [
    "business-rules",
    "business-logic",
    "code-annotations",
    "documentation-generator",
    "rules-engine",
    "code-documentation",
    "markdown-generator",
    "domain-driven-design",
    "technical-debt",
    "codebase-audit",
    "turbo",
    "monorepo",
    "cli",
    "living-documentation",
    "code-comments",
    "static-analysis"
  ],
  "license": "MIT",
  "author": "fmekkaoui",
  "repository": {
    "type": "git",
    "url": "https://github.com/fmekkaoui/ruledoc"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "ruledoc": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run test:coverage && npm run build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.0"
  }
}
